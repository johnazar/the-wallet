{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "paths": {
      "~/*": ["./*"],
      "@/*": ["./*"]
    },
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@types/node", "vite/client", "nuxt/schema", "unplugin-vue-router/client"]
  },
  "exclude": ["node_modules", "dist"],
  "extends": "./.nuxt/tsconfig.json"
}
